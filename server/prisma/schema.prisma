// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         String     @default("ADMIN") // SUPER_ADMIN, ADMIN
  isApproved   Boolean    @default(false)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  events       Event[]
  auditLogs    AuditLog[]
  ConflictRequest ConflictRequest[]
  orgMemberships  OrgMember[]
  eventReports    EventReport[]
}

model Organization {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  logoUrl     String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  members     OrgMember[]
  events      Event[]
}

model OrgMember {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String       @default("MEMBER") // ORG_HEAD, MEMBER
  permissions    String       @default("[]")     // JSON array: ["HOST_EVENTS","VIEW_REPORTS","EDIT_ORG","MANAGE_MEMBERS"]
  createdAt      DateTime     @default(now())
  @@unique([userId, organizationId])
}

model Hall {
  id           String   @id @default(uuid())
  name         String
  capacity     Int
  location     String
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  events       Event[]
}

model Event {
  id                 String    @id @default(uuid())
  title              String
  description        String
  startTime          DateTime
  endTime            DateTime
  hallId             String
  hall               Hall      @relation(fields: [hallId], references: [id])
  status             String    @default("CONFIRMED") // CONFIRMED, PENDING, CANCELLED, CONFLICT_REQUESTED
  category           String
  inviteType         String    @default("PUBLIC") // PUBLIC, INVITE_ONLY
  expectedAttendance Int
  posterUrl          String?
  bannerUrl          String?
  recurrenceRule     String?
  hostEmail          String?
  hostPhone          String?
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])
  createdBy          String
  creator            User      @relation(fields: [createdBy], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  conflictRequests   ConflictRequest[]
  rsvps              RSVP[]
  inviteRequests     InviteRequest[]
  report             EventReport?
}

model EventReport {
  id            String   @id @default(uuid())
  eventId       String   @unique
  event         Event    @relation(fields: [eventId], references: [id])
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
  responses     String   // JSON: questionnaire answers
  reportFileUrl String?  // URL to generated .docx in Supabase Storage
  status        String   @default("DRAFT") // DRAFT, GENERATED, ERROR
  createdAt     DateTime @default(now())
}

model ConflictRequest {
  id              String   @id @default(uuid())
  conflictEventId String
  event           Event    @relation(fields: [conflictEventId], references: [id])
  requestedById   String
  requestedBy     User     @relation(fields: [requestedById], references: [id])
  newEventTitle   String
  newEventStart   DateTime
  newEventEnd     DateTime
  hallId          String
  reason          String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  comment         String?
  createdAt       DateTime @default(now())
}

model RSVP {
  id             String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id])
  userIdentifier String
  userName       String
  status         String
  createdAt      DateTime @default(now())

  @@unique([eventId, userIdentifier])
}

model InviteRequest {
  id            String   @id @default(uuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id])
  requesterName String
  requesterEmail String
  requesterInfo String?
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  comment       String?
  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  targetId  String?
  details   String?
  timestamp DateTime @default(now())
}

model SystemSettings {
  id                     String  @id @default("singleton")
  registrationEnabled    Boolean @default(true)
  maxAdmins              Int     @default(20)
  updatedAt              DateTime @updatedAt
}
